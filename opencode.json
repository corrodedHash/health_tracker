      "cargo fmt": "allow",
      "cargo fmt *": "allow",
      "cargo clippy": "allow",
      "cargo clippy *": "allow",
      "cargo build": "allow",
      "cargo build *": "allow",
      "cargo check": "allow",
      "cargo check *": "allow",
      "cargo test": "allow",
      "cargo test *": "allow",
      "INSTA_UPDATE=1 cargo test *": "allow",
      "cargo run": "allow",
      "cargo run *": "allow",
      "cargo doc": "allow",
      "cargo doc *": "allow",
      "cargo clean": "allow",
      "cargo clean *": "allow",
      "mise run build": "allow",
      "mise run release": "allow",
      "mise run run": "allow",
